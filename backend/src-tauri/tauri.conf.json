{
  "$schema": "https://raw.githubusercontent.com/nicknisi/tauri-settings/v2/templates/tauri.conf.json",
  "productName": "MyTodos",
  "version": "0.1.0",
  "identifier": "com.mytodos.app",
  "build": {
    "frontendDist": "../../frontend/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm start",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "MyTodos",
        "width": 400,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
